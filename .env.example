# ────────────────────────────────────────────────────────────────────────────
# WhatsApp AI Chatbot — environment variables
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.
# ────────────────────────────────────────────────────────────────────────────

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Optional overrides (defaults shown):
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# MAX_COMPLETION_TOKENS=512
# TEMPERATURE=0.7

# ── Cohere ────────────────────────────────────────────────────────────────────
COHERE_API_KEY=...
# COHERE_RERANK_MODEL=rerank-v4.0-fast
# COHERE_RERANK_TOP_N=3
# VECTORSTORE_QUERY_N=8

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
# Your Twilio WhatsApp-enabled number (without 'whatsapp:' prefix):
TWILIO_NUMBER=+14155238886

# ── PostgreSQL database ───────────────────────────────────────────────────────
# Driver: psycopg3 (psycopg[binary]) via the postgresql+psycopg SQLAlchemy dialect.
# Requires PostgreSQL 14+ (LTS: 16 or 17 recommended).
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_NAME=fastsapp_ai_agent
DB_PORT=5432

# ── Vectorstore ───────────────────────────────────────────────────────────────
# Path where ChromaDB persists its data between restarts
VECTORSTORE_PATH=./vectorstore
# Path to the FAQ CSV used for RAG ingestion
CONTENT_CSV_PATH=./content/adventistFAQ.csv

# ── Conversation ─────────────────────────────────────────────────────────────
# Number of prior exchanges to include in every prompt
MAX_HISTORY_MESSAGES=10
# Summarise history when it exceeds this many message pairs
SUMMARIZE_THRESHOLD=8

# ── Bot persona ───────────────────────────────────────────────────────────────
# Override the default system prompt (optional):
# SYSTEM_PROMPT=你是港安醫療中心的客服，請禮貌地在WhatsApp上協助客戶的問題。...

# ── Escalation ────────────────────────────────────────────────────────────────
# Conversations with sentiment score below this threshold are flagged
ESCALATION_SENTIMENT_THRESHOLD=-0.5
# Optional: phone number to notify when a conversation is escalated
# ESCALATION_CONTACT_PHONE=+85212345678
